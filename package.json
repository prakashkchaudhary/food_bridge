{
  "name": "foodbridge",
  "version": "1.0.0",
  "description": "FoodBridge - Connecting food donors with NGOs to reduce waste",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "start:backend": "cd backend && npm start",
    "start:frontend": "cd frontend && npm start",
    "build:frontend": "cd frontend && npm run build",
    "seed:admin": "cd backend && npm run seed:admin",
    "clean": "Remove-Item -Recurse -Force backend/node_modules, frontend/node_modules, node_modules -ErrorAction SilentlyContinue"
  },
  "keywords": [
    "food-donation",
    "waste-reduction",
    "mern-stack",
    "react",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
